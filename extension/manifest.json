{
  "manifest_version": 3,
  "name": "Dutch Vocabulary Helper",
  "version": "1.0",
  "description": "Select a Dutch word on any page, get a translation, add to your vocabulary app.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["http://localhost:8000/*", "https://learning-production-fbb6.up.railway.app/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dutch Vocabulary Helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
